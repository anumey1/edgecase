<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/positioningContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_stone_texture">

    <!-- Left pillar -->
    <ImageView
        android:layout_width="@dimen/pillar_width"
        android:layout_height="match_parent"
        android:layout_gravity="start|center_vertical"
        android:src="@drawable/ic_pillar_left"
        android:scaleType="fitXY"
        android:alpha="0.5"
        android:contentDescription="Left pillar" />

    <!-- Right pillar -->
    <ImageView
        android:layout_width="@dimen/pillar_width"
        android:layout_height="match_parent"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_pillar_right"
        android:scaleType="fitXY"
        android:alpha="0.5"
        android:contentDescription="Right pillar" />

    <!-- Positioning mockup area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="48dp"
        android:paddingRight="48dp"
        android:paddingTop="12dp"
        android:paddingBottom="80dp">

        <!-- Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_dark_seaweed_panel"
            android:padding="10dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SLIVER POSITION"
                android:textAppearance="@style/EngravedHeader"
                android:fontFamily="serif"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- The Astrolabe: phone mockup with draggable sliver -->
        <com.dicereligion.edgecase.PositioningView
            android:id="@+id/positioningView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Position info + Back button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvPositionInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/tarnished_silver" />

            <Button
                android:id="@+id/btnBackToMenuFromPosition"
                android:layout_width="120dp"
                android:layout_height="@dimen/stone_button_height"
                android:background="@drawable/selector_stone_button"
                android:elevation="@dimen/stone_button_elevation"
                android:text="BACK"
                android:textAppearance="@style/StoneButtonText"
                android:textSize="@dimen/text_body"
                android:fontFamily="serif" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
