<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/positioningContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_black">

    <!-- Living background: fractured obsidian + pulsing emerald gems (§6.4) -->
    <com.dicereligion.edgecase.ObsidianCrackView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <!-- Left pillar -->
    <ImageView
        android:layout_width="@dimen/pillar_width_new"
        android:layout_height="match_parent"
        android:layout_gravity="start|center_vertical"
        android:src="@drawable/ic_pillar_serpent_left"
        android:scaleType="fitXY"
        android:alpha="0.85"
        android:contentDescription="Left pillar" />

    <!-- Right pillar -->
    <ImageView
        android:layout_width="@dimen/pillar_width_new"
        android:layout_height="match_parent"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_pillar_serpent_left"
        android:scaleX="-1"
        android:scaleType="fitXY"
        android:alpha="0.85"
        android:contentDescription="Right pillar" />

    <!-- Positioning mockup area. Shared side padding removed (§12.1); each child sets its own
         horizontal margin so the header stays the width of the other screens (L2) while the
         canvas alone gets the extra room. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <!-- Header bar — shared temple lintel (§5.2); margin keeps it same width as other screens -->
        <include
            android:id="@+id/templeHeader"
            layout="@layout/layout_temple_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="52dp"
            android:layout_marginBottom="8dp" />

        <!-- The Astrolabe: phone mockup with draggable sliver — spans pillar-to-pillar (§12.1) -->
        <com.dicereligion.edgecase.PositioningView
            android:id="@+id/positioningView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="46dp" />

        <!-- Position info + action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="52dp"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvPositionInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/tarnished_silver" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnBackToMenuFromPosition"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/stone_button_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/selector_stone_button"
                    android:elevation="@dimen/stone_button_elevation"
                    android:text="BACK"
                    android:textAppearance="@style/SlabButtonText"
                    android:textSize="@dimen/text_body" />

                <Button
                    android:id="@+id/btnCustomizeSliver"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/stone_button_height"
                    android:layout_weight="1"
                    android:background="@drawable/selector_stone_button"
                    android:elevation="@dimen/stone_button_elevation"
                    android:text="CUSTOMIZE"
                    android:textAppearance="@style/SlabButtonText"
                    android:textSize="@dimen/text_body" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
