<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/shortcutsContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_black">

    <!-- Living background: fractured obsidian + pulsing emerald gems (§6.4) -->
    <com.dicereligion.edgecase.ObsidianCrackView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <ImageView
        android:layout_width="@dimen/pillar_width_new"
        android:layout_height="match_parent"
        android:layout_gravity="start|center_vertical"
        android:src="@drawable/ic_pillar_serpent_left"
        android:scaleType="fitXY"
        android:alpha="0.85"
        android:contentDescription="Left pillar" />

    <ImageView
        android:layout_width="@dimen/pillar_width_new"
        android:layout_height="match_parent"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_pillar_serpent_left"
        android:scaleX="-1"
        android:scaleType="fitXY"
        android:alpha="0.85"
        android:contentDescription="Right pillar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="52dp"
        android:paddingRight="52dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <!-- ── Header bar — shared temple lintel (§5.2); ring removed (§5.5) ── -->
        <include
            android:id="@+id/templeHeader"
            layout="@layout/layout_temple_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- ── The Altar ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENT SHORTCUTS"
            android:textAppearance="@style/CaptionSerif"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:fontFamily="serif"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="4dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.38"
            android:background="@drawable/bg_dark_seaweed_panel">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAltarShortcuts"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                android:clipToPadding="false"
                android:padding="4dp" />

            <TextView
                android:id="@+id/tvAltarEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="THE ALTAR LIES BARE — CHOOSE YOUR OFFERINGS BELOW"
                android:textAppearance="@style/BodySerif"
                android:fontFamily="serif"
                android:gravity="center"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Spear divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:src="@drawable/ic_divider_fangs"
            android:scaleType="fitXY"
            android:contentDescription="Divider" />

        <!-- ── The Archives ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AVAILABLE APPS"
            android:textAppearance="@style/CaptionSerif"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:fontFamily="serif"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvArchiveApps"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.42"
            android:scrollbars="vertical" />

        <!-- Action bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.10"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnBackToMenu"
                android:layout_width="0dp"
                android:layout_height="@dimen/stone_button_height"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:background="@drawable/selector_stone_button"
                android:elevation="@dimen/stone_button_elevation"
                android:text="BACK"
                android:textAppearance="@style/SlabButtonText"
                android:textSize="@dimen/text_body" />

            <Button
                android:id="@+id/btnSaveShortcuts"
                android:layout_width="0dp"
                android:layout_height="@dimen/stone_button_height"
                android:layout_weight="1"
                android:background="@drawable/selector_stone_button"
                android:elevation="@dimen/stone_button_elevation"
                android:text="SAVE"
                android:textAppearance="@style/SlabButtonText"
                android:textSize="@dimen/text_body" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
