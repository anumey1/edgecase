<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_black">

    <!-- Living background: fractured obsidian + pulsing emerald gems (§6.4) -->
    <com.dicereligion.edgecase.ObsidianCrackView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <!-- Left pillar -->
    <ImageView
        android:layout_width="@dimen/pillar_width_new"
        android:layout_height="match_parent"
        android:layout_gravity="start|center_vertical"
        android:src="@drawable/ic_pillar_serpent_left"
        android:scaleType="fitXY"
        android:alpha="0.85"
        android:contentDescription="Left pillar" />

    <!-- Right pillar -->
    <ImageView
        android:layout_width="@dimen/pillar_width_new"
        android:layout_height="match_parent"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_pillar_serpent_left"
        android:scaleX="-1"
        android:scaleType="fitXY"
        android:alpha="0.85"
        android:contentDescription="Right pillar" />

    <!-- Dust particle overlay container -->
    <FrameLayout
        android:id="@+id/dustContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false" />

    <!-- Center content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="56dp"
        android:paddingRight="56dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp">

        <!-- Header bar — shared temple lintel (§5.2); main menu keeps default title -->
        <include
            android:id="@+id/templeHeader"
            layout="@layout/layout_temple_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Buttons centered vertically in remaining space -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

        <Button
            android:id="@+id/btnShortcuts"
            android:layout_width="match_parent"
            android:layout_height="@dimen/stone_button_height"
            android:layout_marginBottom="@dimen/margin_wide"
            android:background="@drawable/selector_stone_button"
            android:elevation="@dimen/stone_button_elevation"
            android:text="SHORTCUTS"
            android:textAppearance="@style/SlabButtonText" />

        <Button
            android:id="@+id/btnPosition"
            android:layout_width="match_parent"
            android:layout_height="@dimen/stone_button_height"
            android:layout_marginBottom="@dimen/margin_wide"
            android:background="@drawable/selector_stone_button"
            android:elevation="@dimen/stone_button_elevation"
            android:text="POSITION"
            android:textAppearance="@style/SlabButtonText" />

        <Button
            android:id="@+id/btnDummy"
            android:layout_width="match_parent"
            android:layout_height="@dimen/stone_button_height"
            android:layout_marginBottom="@dimen/margin_wide"
            android:background="@drawable/selector_stone_button"
            android:elevation="@dimen/stone_button_elevation"
            android:text="DUMMY"
            android:textAppearance="@style/SlabButtonText" />

        <!-- Spear divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_divider_fangs"
            android:scaleType="fitXY"
            android:contentDescription="Divider" />

        <Button
            android:id="@+id/btnStartService"
            android:layout_width="match_parent"
            android:layout_height="@dimen/stone_button_height"
            android:layout_marginBottom="@dimen/margin_wide"
            android:background="@drawable/selector_start_button"
            android:elevation="@dimen/stone_button_elevation"
            android:text="Start"
            android:textAppearance="@style/SlabButtonText" />

        <Button
            android:id="@+id/btnStopService"
            android:layout_width="match_parent"
            android:layout_height="@dimen/stone_button_height"
            android:background="@drawable/selector_stop_button"
            android:elevation="@dimen/stone_button_elevation"
            android:text="Stop"
            android:textAppearance="@style/SlabButtonText"
            android:textColor="@color/aged_marble"
            android:shadowColor="#802E8B57"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8" />

        </LinearLayout>

    </LinearLayout>

    <!-- App version — bottom left -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|bottom"
        android:paddingStart="16dp"
        android:paddingBottom="12dp"
        android:textAppearance="@style/CaptionChiseled"
        android:alpha="0.6" />

</FrameLayout>
