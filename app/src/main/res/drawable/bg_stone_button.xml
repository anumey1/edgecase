<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main body: Temple Sandstone -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/temple_sandstone" />
            <corners android:radius="0dp" />
        </shape>
    </item>
    <!-- Bottom bevel: darker sandstone strip for 3D depth -->
    <item
        android:top="-4dp"
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sandstone_bevel" />
            <corners android:radius="0dp" />
        </shape>
    </item>
</layer-list>
