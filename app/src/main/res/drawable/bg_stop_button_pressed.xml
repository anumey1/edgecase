<?xml version="1.0" encoding="utf-8"?>
<!-- Stop pressed: the faint glow dims as the slab sinks -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#20242A" />
        </shape>
    </item>
    <!-- glow line goes dim when pressed -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#26191C1F" />
        </shape>
    </item>
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#1C1F23" />
        </shape>
    </item>
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp"
        android:drawable="@drawable/ic_texture_cracks" />
</layer-list>
