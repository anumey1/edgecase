<?xml version="1.0" encoding="utf-8"?>
<!-- Stop: cold obsidian slab — grey-black body with a faded silver glow line (§ user request) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Outer blocky border — near-black -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#20242A" />
        </shape>
    </item>
    <!-- 2. Faded cold glow line (tarnished silver, low alpha) -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#4D9AA0A6" />
        </shape>
    </item>
    <!-- 3. Grey-black body, lit faintly from below -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#22262B"
                android:endColor="#3B4147" />
        </shape>
    </item>
    <!-- 4. Bottom bevel: darkest strip -->
    <item android:left="4dp" android:top="48dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#17191C" />
        </shape>
    </item>
    <!-- 5. Crack texture across the face -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp"
        android:drawable="@drawable/ic_texture_cracks" />
</layer-list>
